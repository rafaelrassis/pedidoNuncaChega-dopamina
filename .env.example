DATABASE_URL="postgresql://pnc:pnc@localhost:5432/pnc?schema=public"
# Só necessário ao usar Neon: connection string direta (sem pooler), usada pelo Prisma Migrate.
DIRECT_URL="postgresql://pnc:pnc@localhost:5432/pnc?schema=public"
JWT_SECRET="troque_este_segredo_em_producao"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Necessário pro upload de fotos no admin (/admin/comidas, /admin/motoboys).
# Criado automaticamente ao conectar um Vercel Blob store ao projeto
# (Vercel Dashboard → Storage → Create Database → Blob). Localmente, copie
# o valor de lá ou rode `vercel env pull`.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
